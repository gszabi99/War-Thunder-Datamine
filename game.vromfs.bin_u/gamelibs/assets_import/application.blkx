          "dynamic_emissive": "dynamic_emissive",
          "dynamic_emissive_zombie": "dynamic_emissive_zombie",
          "dynamic_emissive_metatex": "dynamic_emissive_metatex",
          "dynamic_eye": "dynamic_eye",
          "dynamic_glass_chrome": "dynamic_glass_chrome",
          "dynamic_hair": "dynamic_hair",
          "dynamic_highlighter": "dynamic_highlighter",
          "dynamic_mask_layered": "dynamic_mask_layered",
