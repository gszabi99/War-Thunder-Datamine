          },
          "setScanPatternSet": {
            "scanPatternSet": "search"
          },
          "setFsmActive": {
            "fsm": "searchModes",
            "active": false
          }
        },
        "setSearchMode": {
          "setModeName": {
            "name": "search"
          },
          "setEnabled": {
            "value": true
          },
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": false
          },
          "setCenterAzimuth": {
            "source": "constant",
            "value": 0.0
          },
          "setFsmActive": [
            {
              "fsm": "search",
              "active": true
            },
            {
              "fsm": "searchModes",
              "active": true
            }
          ],
          "clearTargetsOfInterest": {},
          "setCueEnabled": {
            "value": true
          },
          "setTransiver": {
            "transiver": "search"
          },
          "setCenterElevation": {
            "source": "constant",
            "value": 4.75
          },
          "setScanPatternSet": {
