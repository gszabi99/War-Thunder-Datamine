      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "fsmActivate",
          "stateTo": "search",
          "actions": {
            "setCommonSearchMode": {}
          }
        },
        "showCommonSearchMode": {
          "stateFrom": "search",
          "event": "fsmActivate",
          "stateTo": "search",
          "actions": {
            "setCommonSearchMode": {}
          }
        }
