          },
          "setTransiver": {
            "transiver": "track"
          },
          "setDistGatePos": {
            "source": "constRange",
            "pos": 7500.0,
            "width": 15000.0
          }
        },
        "setVisualLockMode": {
          "setModeName": {
            "name": "acquisition"
          },
          "setEnabled": {
            "value": true
          },
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": true
          },
          "setTransiver": {
            "transiver": "track"
          },
          "setDistGatePos": {
            "source": "targetDesignation",
            "width": 200.0
          }
        },
        "setTrackMode": {
          "setModeName": {
            "name": "track"
          },
          "setEnabled": {
            "value": true
          },
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": false
          },
          "setScanPatternSet": {},
          "setScanPattern": {
            "scanPattern": "track"
          },
          "clearTargetsOfInterest": {},
          "addTargetOfInterest": {},
          "setLastTargetOfInterestActive": {},
          "updateActiveTargetOfInterest": {},
          "setCenterAzimuth": {
            "source": "activeTargetOfInterest"
          },
          "setCenterElevation": {
            "source": "activeTargetOfInterest"
          },
          "setDistGatePos": {
            "source": "activeTargetOfInterest",
            "width": 0.0
          },
          "setFsmActive": {
            "fsm": "track",
            "active": true
          },
          "setTransiver": {
            "transiver": "track"
          }
        },
        "setLockMode": {
          "setModeName": {
            "name": "acquisition"
          },
          "setEnabled": {
            "value": true
          },
          "setDesignatedTarget": {
            "set": true
          },
          "clearTargetsOfInterest": {},
          "setScanPatternSet": {},
          "setScanPattern": {
            "scanPattern": "lock"
          },
          "resetScanPhase": {},
          "setFsmActive": {
            "fsm": "lock",
            "active": true
          },
          "setTransiver": {
            "transiver": "track"
          },
          "setCenterAzimuth": {
            "source": "targetDesignation"
          },
          "setDistGatePos": {
            "source": "targetDesignation",
            "width": 200.0
          }
        }
      },
      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "init",
          "stateTo": "standbyOrSearch",
          "actions": {
            "init": {},
            "setFsmActive": {
              "fsm": "standbyOrSearch",
              "active": true
            }
          }
        },
        "selectTarget": {
          "stateFrom": "standbyOrSearch",
          "command": "selectTarget",
          "actions": {
            "updateActiveDetectedTarget": {},
            "designateTargetUnderCue": {
              "type": "cue",
              "self": true,
              "sensorIndex": 0
            },
            "designateActiveDetectedTarget": {
              "type": "target",
              "self": true,
              "sensorIndex": 0
            }
          }
        },
        "checkLockType0": {
          "stateFrom": "standbyOrSearch",
          "command": "designateTarget",
          "stateTo": "checkLockType0",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": [
                "target",
                "cue"
              ]
            }
          }
        },
        "lock": {
          "stateFrom": "checkLockType0",
          "event": "designationTypeEquals",
          "stateTo": "lock",
          "actions": {
            "setFsmActive": {
              "fsm": "standbyOrSearch",
              "active": false
            },
            "setLockMode": {}
          }
        },
        "checkLockTypeLos": {
          "stateFrom": "checkLockType0",
          "event": "designationTypeNotEquals",
          "stateTo": "checkLockTypeLos",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": "los"
            }
          }
        },
        "losLock": {
          "stateFrom": "checkLockTypeLos",
          "event": "designationTypeEquals",
          "stateTo": "losLock",
          "actions": {
            "setFsmActive": {
              "fsm": "standbyOrSearch",
              "active": false
            },
            "setLosVisualPreLockMode": {},
            "setLosLockMode": {}
          }
        },
        "checkLockTypeVisual": {
          "stateFrom": "checkLockTypeLos",
          "event": "designationTypeNotEquals",
          "stateTo": "checkLockTypeVisual",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": "visual"
            }
          }
        },
        "visualLock": {
          "stateFrom": "checkLockTypeVisual",
          "event": "designationTypeEquals",
          "stateTo": "visualLock",
          "actions": {
            "setFsmActive": {
              "fsm": "standbyOrSearch",
              "active": false
            },
            "setLosVisualPreLockMode": {},
            "setVisualLockMode": {}
          }
        },
        "finishLockTypeCheck": {
          "stateFrom": "checkLockTypeVisual",
          "event": "designationTypeNotEquals",
          "stateTo": "standbyOrSearch"
        },
        "track": {
          "stateFrom": [
            "lock",
            "losLock",
            "visualLock"
          ],
          "event": "targetDetected",
          "stateTo": "track",
          "actions": {
            "setFsmActive": [
              {
                "fsm": "lock",
                "active": false
              },
              {
                "fsm": "lock",
                "active": false
              }
            ],
            "setTrackMode": {}
          }
        },
        "failedLock": {
          "stateFrom": [
            "lock",
            "losLock",
            "visualLock"
          ],
          "event": "scanFinished",
          "stateTo": "standbyOrSearch",
          "actions": {
            "setFsmActive": [
              {
                "fsm": "lock",
                "active": false
              },
              {
                "fsm": "standbyOrSearch",
                "active": true
              }
            ]
          }
        },
        "finishedTrack": {
          "stateFrom": "track",
          "event": "targetsOfInterestCleanup",
          "command": [
            "selectTarget",
            "designateTarget"
          ],
          "stateTo": "standbyOrSearch",
          "actions": {
            "setFsmActive": [
              {
                "fsm": "track",
                "active": false
              },
              {
                "fsm": "standbyOrSearch",
                "active": true
              }
            ]
          }
        },
        "switchScanPattern": {
          "stateFrom": "standbyOrSearch",
          "command": "scanPatternSwitch",
          "actions": {
            "setNextScanPattern": {}
          }
        },
        "switchScopeRange": {
          "command": "rangeSwitch",
          "actions": {
            "setNextScopeRange": {}
          }
        }
      }
    },
    "search": {
      "stateInit": "search",
      "transitions": {
        "scan": {
          "event": "update",
          "actions": {
            "setCenterAzimuth": {
              "source": "body"
            },
            "scan": {}
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "setDistGatePos": {
              "source": "continuousScale",
              "width": 0.0
            },
            "setRelSpeedGatePos": {
              "source": "continuousScale",
              "width": 0.0
            },
            "detectTarget": {}
          }
        },
        "addTarget": {
          "event": "targetDetected",
          "actions": {
            "addTarget": {},
            "updateActiveDetectedTarget": {}
          }
        },
        "switchSelectedTarget": {
          "command": "switchTarget",
          "actions": {
            "setNextDetectedTargetActive": {}
          }
        },
        "setCueAzimuth": {
          "command": "cueAxisX",
          "actions": {
            "setCueAzimuth": {}
          }
        },
        "setCueDist": {
          "command": "cueAxisY",
          "actions": {
            "setCueDist": {}
          }
        },
        "setCueElevation": {
          "command": "cueAxisZ",
          "actions": {
            "setCueElevation": {}
          }
        }
      }
    },
    "standbyOrSearch": {
      "stateInit": "init",
      "actionsTemplates": {
        "setStandbyMode": {
          "setModeName": {
            "name": "standby"
          },
          "setEnabled": {
            "value": false
          },
          "clearTargetsOfInterest": {},
          "setTransiver": {
            "transiver": "search"
          },
          "setCenterElevation": {
            "source": "constant",
