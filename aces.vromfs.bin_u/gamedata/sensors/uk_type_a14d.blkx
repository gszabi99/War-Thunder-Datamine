      "elevationLimits": [
        -6.0,
        73.0
      ],
      "period": 0.25,
      "width": 2.0,
      "barHeight": 1.0,
      "barsCount": 1,
      "rowMajor": false,
      "indicate": true
    },
    "losLock": {
      "type": "pyramide",
      "azimuthLimits": [
        -45.0,
        45.0
      ],
      "elevationLimits": [
        -6.0,
        73.0
      ],
      "period": 0.25,
      "width": 2.0,
      "barHeight": 1.0,
      "barsCount": 1,
      "rowMajor": false,
      "indicate": true
