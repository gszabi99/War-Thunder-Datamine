      "azimuthLimits": [
        -45.0,
        45.0
      ],
      "elevationLimits": [
        -6.0,
        73.0
      ],
      "track": true
    }
  },
  "signals": {
    "common": {
      "groundClutter": false,
      "friendFoeId": true,
      "absDopplerSpeed": true,
      "distance": {
        "presents": true,
        "minValue": 500.0,
        "maxValue": 15000.0
      },
      "dopplerSpeed": {
        "presents": true,
        "minValue": 50.0,
        "maxValue": 1000.0,
        "signalWidthMin": 5.0,
        "width": 0.0
      }
    }
  },
  "scanPatternSets": {
    "search": {
      "scanPattern1": "search90"
    }
  },
  "scopeRangeSets": {
    "common": {
      "range1": 10000.0,
      "range2": 15000.0
    }
  },
  "fsms": {
    "main": {
      "stateInit": "init",
      "actionsTemplates": {
        "init": {
          "setEnabled": {
            "value": false
          },
          "setTransiver": {
