          }
        }
      },
      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "init",
          "stateTo": "standby",
          "actions": {
            "setStandbyMode": {}
          }
        },
        "switchToSearch": {
          "stateFrom": "standby",
          "command": "switch",
          "event": "enable",
          "stateTo": "search",
          "actions": {
            "setSearchMode": {}
          }
        },
        "switchToStandby": {
          "stateFrom": "search",
          "command": "switch",
          "event": "disable",
          "stateTo": "standby",
          "actions": {
            "resetSearchMode": {},
            "setStandbyMode": {}
          }
        },
        "activateStandby": {
          "stateFrom": "standbyInactive",
          "event": "fsmActivate",
          "stateTo": "standby",
          "actions": {
            "resetSearchMode": {},
            "setStandbyMode": {}
          }
        },
        "deactivateStandby": {
          "stateFrom": "standby",
          "event": "fsmDeactivate",
          "stateTo": "standbyInactive"
        },
        "activateSearch": {
          "stateFrom": "searchInactive",
          "event": "fsmActivate",
          "stateTo": "search",
          "actions": {
            "setSearchMode": {}
          }
        },
        "deactivateSearch": {
          "stateFrom": "search",
          "event": "fsmDeactivate",
          "stateTo": "searchInactive",
          "actions": {
            "resetSearchMode": {}
          }
        }
      }
    },
    "lock": {
      "stateInit": "lock",
      "transitions": {
        "scan": {
          "event": "update",
          "actions": {
            "scan": {}
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "detectTarget": {
              "ignoreOwnWeapon": true,
              "rangeMult": 1.0
            }
          }
        }
      }
    },
    "track": {
      "stateInit": "track",
      "transitions": {
        "detect": {
          "event": "update",
          "actions": {
            "detectTarget": {
              "ignoreOwnWeapon": true,
              "rangeMult": 1.0
            }
          }
        },
        "track": {
          "event": "targetDetected",
          "actions": {
            "updateActiveTargetOfInterest": {
              "dirFilter": {
                "alpha": 0.8,
                "betta": 0.1,
                "rateLim": [
                  0.78,
                  0.78
                ],
                "limTimeOut": 1.0,
                "inertialTimeMax": 1.0
              },
              "distFilter": {
                "alpha": 0.8,
                "betta": 0.2,
                "accelLim": [
                  150.0,
                  150.0
                ],
                "limTimeOut": 1.0,
                "inertialTimeMax": 1.0
              }
            },
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setCenterElevation": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        },
        "extrapolate": {
          "event": "targetNotDetected",
          "actions": {
            "extrapolateTargetsOfInterest": {},
            "clearTargetsOfInterest": {
              "timeOut": 5.0,
              "dirRateLim": 1.0
            },
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setCenterElevation": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        }
      }
    },
    "searchModes": {
