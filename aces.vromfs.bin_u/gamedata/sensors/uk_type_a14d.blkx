            "distanceRange": [
              0.0,
              15000.0
            ]
          },
          "setScopeRangeSet": {
            "scopeRangeSet": "common"
          },
          "setFsmActive": {
            "fsm": "searchModes",
            "active": true
          }
        },
        "setLosVisualPreLockMode": {
          "setEnabled": {
            "value": true
          },
          "setScanPatternSet": {},
          "setScanPattern": {
            "scanPattern": "losLock"
          },
          "resetScanPhase": {},
          "setCenterAzimuth": {
            "source": "targetDesignation"
          },
          "setCenterElevation": {
            "source": "targetDesignation"
          },
          "clearTargetsOfInterest": {},
          "setFsmActive": {
            "fsm": "lock",
            "active": true
          }
        },
        "setLosLockMode": {
          "setModeName": {
            "name": "acquisition"
          },
          "setEnabled": {
