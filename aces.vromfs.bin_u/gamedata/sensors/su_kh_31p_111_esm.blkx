{
  "type": "radar",
  "name": "Kh-31 L-111 ESM",
  "transivers": {
    "common": {
      "visibilityType": "radarIntercept",
      "band": 8,
      "active": false,
      "sideLobesAttenuation": -60.0,
      "multipathEffect": [
        0.0,
        1.0,
        60.0,
        0.0
      ],
      "receiver": {
        "rcs": 5.0,
        "range": 100000.0,
        "rangeMax": 250000.0,
        "antenna": {
          "angleHalfSens": 8.0,
          "sideLobesSensitivity": -60.0
        }
      }
    }
  },
  "scanPatterns": {
    "searchNarrow": {
      "type": "pyramide",
      "azimuthLimits": [
        -20.0,
        20.0
      ],
      "elevationLimits": [
        -12.0,
        0.0
      ],
      "pitchStabLimit": 45.0,
      "rollStabLimit": 45.0,
      "period": 16.0,
      "width": 10.0,
      "barHeight": 6.0,
      "barsCount": 2,
      "rowMajor": true,
      "barsOneWay": true,
      "preciseMinor": true,
      "tws": true,
      "centerElevation": -6.0
    },
    "searchWide": {
      "type": "pyramide",
      "azimuthLimits": [
        -20.0,
        20.0
      ],
      "elevationLimits": [
        -12.0,
        0.0
      ],
      "pitchStabLimit": 45.0,
      "rollStabLimit": 45.0,
      "period": 32.0,
      "width": 20.0,
      "barHeight": 6.0,
      "barsCount": 2,
      "rowMajor": true,
      "barsOneWay": true,
      "preciseMinor": true,
      "tws": true,
      "centerElevation": -6.0
    },
    "bvrLockSearch": {
      "type": "pyramide",
      "azimuthLimits": [
        -20.0,
        20.0
      ],
      "elevationLimits": [
        -12.0,
        0.0
      ],
      "pitchStabLimit": 45.0,
      "rollStabLimit": 45.0,
      "period": 0.5,
      "width": 30.0,
      "barHeight": 6.0,
      "barsCount": 1,
      "rowMajor": false,
      "preciseMinor": true,
      "tws": true,
      "centerElevation": -6.0,
      "indicate": true
    },
    "track": {
      "type": "no",
      "azimuthLimits": [
        -20.0,
        20.0
      ],
      "elevationLimits": [
        -12.0,
        0.0
      ]
    }
  },
  "signals": {
    "search": {
      "aircraftAsTarget": true,
      "groundVehiclesAsTarget": true,
      "shipsAsTarget": true,
      "detectWeapon": false,
      "targetId": true,
      "groundClutter": false,
      "rangeFinder": false,
      "friendFoeId": true,
      "showBScope": false,
      "showCScope": true
    },
    "track": {
      "aircraftAsTarget": true,
      "groundVehiclesAsTarget": true,
      "shipsAsTarget": true,
      "detectWeapon": false,
      "targetId": [
        true,
        true
      ],
      "groundClutter": false,
      "rangeFinder": false,
      "track": true,
      "angularAccuracy": 0.06
    }
  },
  "scanPatternSets": {
    "search": {
      "scanPattern1": "searchNarrow",
      "scanPattern2": "searchWide"
    }
  },
  "scopeRangeSets": {
    "search": {
      "range1": 200000.0
    }
  },
  "fsms": {
    "main": {
      "stateInit": "init",
      "actionsTemplates": {
        "init": {
          "setEnabled": {
            "value": false
          },
          "setCenterAzimuth": {
            "source": "constant",
            "value": 0.0
          },
          "setCenterElevation": {
            "source": "constant",
            "value": 0.0
          },
          "setScanPatternSet": {
            "scanPatternSet": "search"
          },
          "setScopeRangeSet": {
            "scopeRangeSet": "search"
          },
          "setTargetDesignationRange": {
            "azimuthRange": [
              -20.0,
              20.0
            ],
            "elevationRange": [
              -12.0,
              0.0
            ],
            "azimuthWidth": 2.0
          },
          "setTransiver": {
            "transiver": "common"
          },
          "setSignal": {
            "signal": "search"
          }
        },
        "setStandbyMode": {
          "setModeName": {
            "name": "ESM standby"
          },
          "setEnabled": {
            "value": false
          },
          "setScanPatternSet": {
            "scanPatternSet": "search"
          },
          "setScopeRangeSet": {
            "scopeRangeSet": "search"
          },
          "setSignal": {
            "signal": "search"
          },
          "setDesignatedTarget": {
            "set": false
          }
        },
        "resetStandbyMode": {},
        "setSearchMode": {
          "setModeName": {
            "name": "ESM search"
          },
          "setEnabled": {
            "value": true
          },
          "setFsmActive": {
            "fsm": "tws",
            "active": true
          },
          "setScanPatternSet": {
            "scanPatternSet": "search"
          },
          "setScopeRangeSet": {
            "scopeRangeSet": "search"
          },
          "setSignal": {
            "signal": "search"
          },
          "setDesignatedTarget": {
            "set": false
          },
          "setDesignationSourceType": {
            "sourceType": "dummy"
          }
        },
        "resetSearchMode": {
          "setFsmActive": {
            "fsm": "tws",
            "active": false
          },
          "clearTargetsOfInterest": {}
        },
        "setBvrLockMode": {
          "setModeName": {
            "name": "ESM acquisition"
          },
          "setEnabled": {
            "value": true
          },
          "setScanPatternSet": {},
          "setScanPattern": {
            "scanPattern": "bvrLockSearch"
          },
          "resetScanPhase": {},
          "setCenterAzimuth": {
            "source": "targetDesignation"
          },
          "setCenterElevation": {
            "source": "targetDesignation"
          },
          "setFsmActive": {
            "fsm": "lock",
            "active": true
          },
          "setSignal": {
            "signal": "track"
          },
          "setDesignatedTarget": {
            "set": true
          },
          "setDesignationSourceType": {}
        },
        "resetBvrLockMode": {
          "setFsmActive": {
            "fsm": "lock",
            "active": false
          }
        },
        "setTrackMode": {
          "setModeName": {
            "name": "ESM track"
          },
          "setEnabled": {
            "value": true
          },
          "setScanPatternSet": {},
          "setScanPattern": {
            "scanPattern": "track"
          },
          "clearTargetsOfInterest": {},
          "addTargetOfInterest": {},
          "setLastTargetOfInterestActive": {},
          "updateActiveTargetOfInterest": {},
          "setCenterAzimuth": {
            "source": "activeTargetOfInterest"
          },
          "setCenterElevation": {
            "source": "activeTargetOfInterest"
          },
          "setDistGatePos": {
            "source": "activeTargetOfInterest",
            "width": 0.0
          },
          "setFsmActive": {
            "fsm": "track",
            "active": true
          },
          "setSignal": {
            "signal": "track"
          },
          "setDesignationSourceType": {}
        },
        "resetTrackMode": {
          "clearTargetsOfInterest": {},
          "setCenterAzimuth": {
            "source": "constant",
            "value": 0.0
          },
          "setCenterElevation": {
            "source": "constant",
            "value": 0.0
          },
          "setFsmActive": {
            "fsm": "track",
            "active": false
          },
          "setDesignationSourceType": {
            "sourceType": "dummy"
          }
        }
      },
      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "init",
          "stateTo": "standby",
          "actions": {
            "init": {},
            "setStandbyMode": {}
          }
        },
        "switchOn": {
          "stateFrom": "standby",
          "command": "switch",
          "event": "enable",
          "stateTo": "search",
          "actions": {
            "setSearchMode": {}
          }
        },
        "switchOff": {
          "stateFrom": "search",
          "command": "switch",
          "event": "disable",
          "stateTo": "standby",
          "actions": {
            "resetSearchMode": {},
            "setStandbyMode": {}
          }
        },
        "switchScanPattern": {
          "stateFrom": [
            "standby",
            "search"
          ],
          "command": "scanPatternSwitch",
          "actions": {
            "setNextScanPattern": {}
          }
        },
        "switchScopeRange": {
          "command": "rangeSwitch",
          "actions": {
            "setNextScopeRange": {}
          }
        },
        "bvrLock": {
          "stateFrom": "search",
          "command": "selectTarget",
          "actions": {
            "designateTargetUnderCue": {
              "type": "cue",
              "self": true,
              "sensorIndex": 0,
              "selectTarget": true
            },
            "designateActiveDetectedTarget": {
              "type": "target",
              "self": true,
              "sensorIndex": 0
            }
          }
        },
        "checkBvrType0": {
          "stateFrom": "search",
          "command": "designateTarget",
          "stateTo": "checkBvrType0",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": [
                "target",
                "cue"
              ]
            }
          }
        },
        "bvrLockResponce": {
          "stateFrom": "checkBvrType0",
          "event": "designationTypeEquals",
          "stateTo": "bvrLock",
          "actions": {
            "resetSearchMode": {},
            "setBvrLockMode": {}
          }
        },
        "returnToSearchMode": {
          "stateFrom": "checkBvrType0",
          "event": "designationTypeNotEquals",
          "stateTo": "search"
        },
        "bvrLockToBVRTrack": {
          "stateFrom": "bvrLock",
          "event": "targetDetected",
          "stateTo": "bvrTrack",
          "actions": {
            "resetBvrLockMode": {},
            "setTrackMode": {}
          }
        },
        "failedBvrLock": {
          "stateFrom": "bvrLock",
          "event": "scanFinished",
          "stateTo": "search",
          "actions": {
            "resetBvrLockMode": {},
            "setSearchMode": {}
          }
        },
        "finishedBvrTrack": {
          "stateFrom": "bvrTrack",
          "event": "targetsOfInterestCleanup",
          "command": [
            "selectTarget",
            "switch"
          ],
          "stateTo": "search",
          "actions": {
            "resetTrackMode": {},
            "setSearchMode": {}
          }
        },
        "finishBvrTrackAndSwitchOff": {
          "stateFrom": "bvrTrack",
          "event": "disable",
          "stateTo": "standby",
          "actions": {
            "resetTrackMode": {},
            "setStandbyMode": {}
          }
        }
      }
    },
    "tws": {
      "stateInit": [
        "search",
        "search"
      ],
      "transitions": {
        "scan": {
          "event": "update",
          "actions": {
            "scan": {},
            "extrapolateTargetsOfInterest": {},
            "clearTargetsOfInterest": {
              "timeOut": 16.0
            },
            "setCenterAzimuth": [
              {
                "source": "constant",
                "value": 0.0
              },
              {
                "source": "designationCue"
              }
            ],
            "setCenterElevation": [
              {
                "source": "constant",
                "value": 0.0
              },
              {
                "source": "designationCue"
              }
            ]
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "setDistGatePos": {
              "source": "continuousScale",
              "width": 0.0,
              "widthRange": 200000.0
            },
            "setRelSpeedGatePos": {
              "source": "continuousScale",
              "width": 0.0,
              "widthRange": 1000.0
            },
            "detectTarget": {}
          }
        },
        "addTarget": {
          "event": "targetDetected",
          "actions": {
            "updateTargetOfInterest": {
              "limit": 100,
              "timeMin": 2.0,
              "posGateTimeInitial": [
                2.0,
                4.0
              ],
              "posGateRangeInitial": 1500.0,
              "posGateMaxTime": 2.0,
              "posGateRange": [
                0.0,
                1000.0
              ],
              "dopplerSpeedGateMaxTime": 2.0,
              "dopplerSpeedGateRange": [
                0.0,
                400.0
              ]
            },
            "updateActiveDetectedTarget": {}
          }
        },
        "switchSelectedTarget": {
          "command": "switchTarget",
          "actions": {
            "setNextDetectedTargetActive": {}
          }
        },
        "setCueAzimuth": {
          "command": "cueAxisX",
          "actions": {
            "setCueAzimuth": {}
          }
        },
        "setCueDist": {
          "command": "cueAxisY",
          "actions": {
            "setCueDist": {}
          }
        },
        "setCueElevation": {
          "command": "cueAxisZ",
          "actions": {
            "setCueElevation": {}
          }
        },
        "setSelectedTarget": {
          "command": "switchToTarget",
          "actions": {
            "setDetectedTargetActive": {}
          }
        },
        "centerZone": {
          "command": "directionAxesReset",
          "actions": {
            "setCueToBoresight": {},
            "setCenterAzimuth": {
              "source": "designationCue"
            },
            "setCenterElevation": {
              "source": "designationCue"
            },
            "updateActiveDetectedTarget": {}
          }
        }
      }
    },
    "lock": {
      "stateInit": "lock",
      "transitions": {
        "scan": {
          "event": "update",
          "actions": {
            "scan": {
              "singleTargetScan": true
            }
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "detectTarget": {
              "ignoreOwnWeapon": true,
              "rangeMult": 1.0
            }
          }
        }
      }
    },
    "track": {
      "stateInit": "track",
      "transitions": {
        "detect": {
          "event": "update",
          "actions": {
            "detectTarget": {
              "ignoreOwnWeapon": true,
              "rangeMult": 1.0
            }
          }
        },
        "track": {
          "event": "targetDetected",
          "actions": {
            "updateActiveTargetOfInterest": {},
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setCenterElevation": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        },
        "extrapolate": {
          "event": "targetNotDetected",
          "actions": {
            "extrapolateTargetsOfInterest": {},
            "clearTargetsOfInterest": {
              "timeOut": 16.0,
              "dirRateLim": 1.0
            },
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setCenterElevation": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        }
      }
    }
  },
