{
  "type": "radar",
  "name": "AN/MPQ-53",
  "transivers": {
    "track": {
      "power": 450.0,
      "band": 6,
      "rcs": 4.0,
      "range": 100000.0,
      "rangeMax": 180000.0,
      "antenna": {
        "angleHalfSens": 6.0,
        "sideLobesSensitivity": -32.0
      }
    }
  },
  "illuminationTransmitter": {
    "power": 450.0,
    "antenna": {
      "angleHalfSens": 2.8,
      "sideLobesSensitivity": -35.0
    }
  },
  "scanPatterns": {
    "lock": {
      "type": "pyramide",
      "azimuthLimits": [
        -180.0,
        180.0
      ],
      "elevationLimits": [
        -10.7,
        89.6
      ],
      "yawStabLimit": 180.0,
      "pitchStabLimit": 89.6,
      "rollStabLimit": 10.0,
      "period": 1.0,
      "width": 22.5,
      "barHeight": 1.0,
      "barsCount": 6,
      "rowMajor": false,
      "indicate": true
    },
    "losLock": {
      "type": "pyramide",
      "azimuthLimits": [
        -180.0,
        180.0
      ],
      "elevationLimits": [
        -10.7,
        89.6
      ],
      "yawStabLimit": 180.0,
      "pitchStabLimit": 89.6,
      "rollStabLimit": 10.0,
      "period": 0.1,
      "width": 1.5,
      "barHeight": 1.0,
      "barsCount": 3,
      "rowMajor": false,
      "indicate": true
    },
    "track": {
      "type": "pyramide",
      "azimuthLimits": [
        -180.0,
        180.0
      ],
      "elevationLimits": [
        -10.7,
        89.6
      ],
      "yawStabLimit": 180.0,
      "pitchStabLimit": 89.6,
      "rollStabLimit": 10.0,
      "period": 1.0,
      "width": 45.0,
      "barHeight": 5.0,
      "barsCount": 18,
      "rowMajor": false,
      "preciseMinor": true,
      "tws": true
    },
    "fastTws": {
      "type": "pyramide",
      "azimuthLimits": [
        -180.0,
        180.0
      ],
      "elevationLimits": [
        -10.7,
        89.6
      ],
      "yawStabLimit": 180.0,
      "pitchStabLimit": 89.6,
      "rollStabLimit": 10.0,
      "period": 0.4,
      "width": 45.0,
      "barHeight": 5.0,
      "barsCount": 18,
      "rowMajor": false,
      "preciseMinor": true,
      "tws": true
    }
  },
  "signals": {
    "track": {
      "groundClutter": false,
      "absDopplerSpeed": true,
      "track": true,
      "distance": {
        "presents": true,
        "minValue": 75.0,
        "maxValue": 80000.0
      },
      "dopplerSpeed": {
        "presents": true,
        "minValue": 15.0,
        "maxValue": 2000.0,
        "signalWidthMin": 5.0,
        "width": 0.0
      }
    }
  },
  "fsms": {
    "main": {
      "stateInit": "init",
      "actionsTemplates": {
        "init": {
          "setEnabled": {
            "value": false
          },
          "setTargetDesignationRange": {},
          "setTransiver": {
            "transiver": "track"
          },
          "setSignal": {
            "signal": "track"
          }
        },
        "setStandbyMode": {
          "setModeName": {
            "name": "standby"
          },
          "setEnabled": {
            "value": false
          },
          "setScanPattern": {
            "scanPattern": "lock"
          },
          "setCenterAzimuth": {
            "source": "constant",
            "value": 0.0
          },
          "clearTargetsOfInterest": {},
          "setFsmActive": [
            {
              "fsm": "lock",
              "active": false
            },
            {
              "fsm": "track",
              "active": false
            }
          ],
          "setCenterElevation": {
            "source": "constant",
            "value": 22.5
          }
        },
        "setLockModeCommon1": {
          "setModeName": {
            "name": "acquisition"
          },
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": true
          },
          "setEnabled": {
            "value": true
          },
          "setCenterElevation": {
            "source": "constant",
            "value": 22.5
          },
          "setDistGatePos": {
            "source": "targetDesignation",
            "width": 5000.0
          }
        },
        "setLockModeCommon2": {
          "resetScanPhase": {},
          "setCenterAzimuth": {
            "source": "targetDesignation"
          },
          "clearTargetsOfInterest": {},
          "setFsmActive": {
            "fsm": "lock",
            "active": true
          },
          "setCenterElevation": {
            "source": "constant",
            "value": 22.5
          },
          "setDistGatePos": {
            "source": "targetDesignation",
            "width": 5000.0
          }
        },
        "setLockModeCue": {
          "setLockModeCommon1": {},
          "setScanPattern": {
            "scanPattern": "lock"
          },
          "setLockModeCommon2": {}
        },
        "setLockModeTarget": {
          "setLockModeCommon1": {},
          "setScanPattern": {
            "scanPattern": "lock"
          },
          "setLockModeCommon2": {}
        },
        "setLosVisualLockModeCommon": {
          "setEnabled": [
            {
              "value": true
            },
            {
              "value": true
            }
          ],
          "setScanPattern": {
            "scanPattern": "losLock"
          },
          "resetScanPhase": {},
          "clearTargetsOfInterest": {},
          "setCenterAzimuth": {
            "source": "targetDesignation"
          },
          "setCenterElevation": {
            "source": "targetDesignation"
          },
          "setFsmActive": {
            "fsm": "lock",
            "active": true
          },
          "setModeName": {
            "name": "acquisition"
          }
        },
        "setLosLockMode": {
          "setLosVisualLockModeCommon": {},
          "setWeaponDetectionAllowance": {
            "source": "targetDesignation"
          },
          "setDesignatedTarget": {
            "set": false
          },
          "setDistGatePos": {
            "source": "constRange",
            "pos": 40000.0,
            "width": 80000.0
          }
        },
        "setVisualLockMode": {
          "setLosVisualLockModeCommon": {},
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": true
          },
          "setDistGatePos": {
            "source": "targetDesignation",
            "width": 2000.0
          }
        },
        "setTrackMode": {
          "setModeName": {
            "name": "track"
          },
          "setEnabled": {
            "value": true
          },
          "setWeaponDetectionAllowance": {
            "source": "const",
            "value": true
          },
          "setDesignatedTarget": {
            "set": false
          },
          "setScanPattern": {
            "scanPattern": "track"
          },
          "clearTargetsOfInterest": {},
          "addTargetOfInterest": {},
          "setLastTargetOfInterestActive": {},
          "updateActiveTargetOfInterest": {},
          "setCenterAzimuth": {
            "source": "activeTargetOfInterest"
          },
          "setCenterElevation": {
            "source": "activeTargetOfInterest"
          },
          "setDistGatePos": {
            "source": "activeTargetOfInterest",
            "width": 0.0
          },
          "setFsmActive": [
            {
              "fsm": "track",
              "active": true
            },
            {
              "fsm": "illumination",
              "active": true
            }
          ]
        },
        "resetTrackMode": {
          "setFsmActive": {
            "fsm": "illumination",
            "active": false
          }
        }
      },
      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "init",
          "stateTo": "standby",
          "actions": {
            "init": {},
            "setStandbyMode": {}
          }
        },
        "checkLockTypeCue": {
          "stateFrom": "standby",
          "command": "designateTarget",
          "stateTo": "checkLockTypeCue",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": "cue"
            }
          }
        },
        "lockCue": {
          "stateFrom": "checkLockTypeCue",
          "event": "designationTypeEquals",
          "stateTo": "lockCue",
          "actions": {
            "setLockModeCue": {}
          }
        },
        "checkLockTypeTarget": {
          "stateFrom": "checkLockTypeCue",
          "event": "designationTypeNotEquals",
          "stateTo": "checkLockTypeTarget",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": "target"
            }
          }
        },
        "lockTarget": {
          "stateFrom": "checkLockTypeTarget",
          "event": "designationTypeEquals",
          "stateTo": "lockTarget",
          "actions": {
            "setLockModeTarget": {}
          }
        },
        "checkLockTypeLos": [
          {
            "stateFrom": "checkLockTypeTarget",
            "event": "designationTypeNotEquals",
            "stateTo": "checkLockTypeLos",
            "actions": {
              "checkDesignationTypeEquals": {
                "type": "los"
              }
            }
          },
          {
            "stateFrom": "checkLockTypeLos",
            "event": "designationTypeNotEquals",
            "stateTo": "checkLockTypeVisual",
            "actions": {
              "checkDesignationTypeEquals": {
                "type": "visual"
              }
            }
          }
        ],
        "lockLos": {
          "stateFrom": "checkLockTypeLos",
          "event": "designationTypeEquals",
          "stateTo": "losLock",
          "actions": {
            "setLosLockMode": {}
          }
        },
        "lockVisual": {
          "stateFrom": "checkLockTypeVisual",
          "event": "designationTypeEquals",
          "stateTo": "visualLock",
          "actions": {
            "setVisualLockMode": {}
          }
        },
        "finishTypeCheck": {
          "stateFrom": "checkLockTypeVisual",
          "event": "designationTypeNotEquals",
          "stateTo": "standby"
        },
        "track": {
          "stateFrom": [
            "lockCue",
            "lockTarget",
            "losLock",
            "visualLock"
          ],
          "event": "targetDetected",
          "stateTo": "track",
          "actions": {
            "setTrackMode": {},
            "setFsmActive": {
              "fsm": "lock",
              "active": false
            }
          }
        },
        "failedLock": {
          "stateFrom": [
            "lockCue",
            "lockTarget",
            "losLock",
            "visualLock"
          ],
          "event": "scanFinished",
          "stateTo": "standby",
          "actions": {
            "setStandbyMode": {},
            "setFsmActive": {
              "fsm": "lock",
              "active": false
            }
          }
        },
        "finishedTrack": {
          "stateFrom": "track",
          "event": "targetsOfInterestCleanup",
          "command": [
            "selectTarget",
            "designateTarget"
          ],
          "stateTo": "standby",
          "actions": {
            "resetTrackMode": {},
            "setStandbyMode": {},
            "setFsmActive": {
              "fsm": "track",
              "active": false
            }
          }
        }
      }
    },
    "lock": {
      "stateInit": "lock",
      "transitions": {
        "scan": {
          "event": "update",
          "actions": {
            "scan": {}
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "detectTarget": {
              "ignoreOwnWeapon": true,
              "rangeMult": 1.0
            }
          }
        }
      }
    },
    "track": {
      "stateInit": "track",
      "transitions": {
        "scan": {
          "event": "update",
          "stateFrom": "track",
          "stateTo": "search",
          "actions": {
            "scan": {
              "ignoreOwnWeapon": true
            },
            "extrapolateTargetsOfInterest": {},
            "clearTargetsOfInterest": {
              "timeOut": 2.0
            },
            "setCueToActiveTargetOfInterest": {},
            "update": {}
          }
        },
        "scanTrack": {
          "stateFrom": "search",
          "event": "update",
          "stateTo": "track",
          "actions": {
            "scan": {
              "ignoreOwnWeapon": true,
              "scanPattern": "fastTws"
            },
            "extrapolateTargetsOfInterest": {},
            "clearTargetsOfInterest": {
              "timeOut": 2.0
            },
            "setCueToActiveTargetOfInterest": {},
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        },
        "detect": {
          "event": "targetInSight",
          "actions": {
            "setDistGatePos": {
              "source": "continuousScale",
              "width": 0.0
            },
            "setRelSpeedGatePos": {
              "source": "continuousScale",
              "width": 0.0
            },
            "detectTarget": {
              "ignoreOwnWeapon": true
            }
          }
        },
        "addTarget": {
          "stateFrom": "search",
          "event": "targetDetected",
          "actions": {
            "updateTargetOfInterest": {
              "limit": 30,
              "posGateTimeInitial": [
                2.0,
                4.0
              ],
              "posGateRangeInitial": 1500.0,
              "posGateMaxTime": 2.0,
              "posGateRange": [
                50.0,
                2000.0
              ],
              "dopplerSpeedGateMaxTime": 2.0,
              "dopplerSpeedGateRange": [
                0.0,
                400.0
              ]
            },
            "updateActiveDetectedTarget": [
              {},
              {}
            ],
            "setCueToActiveTargetOfInterest": [
              {},
              {}
            ]
          }
        },
        "addTargetTrack": {
          "stateFrom": "track",
          "event": "targetDetected",
          "actions": {
            "updateTargetOfInterest": {
              "limit": 30,
              "onlyExisting": true,
              "posGateTimeInitial": [
                2.0,
                4.0
              ],
              "posGateRangeInitial": 1500.0,
              "posGateMaxTime": 2.0,
              "posGateRange": [
                0.0,
                1000.0
              ],
              "dopplerSpeedGateMaxTime": 2.0,
              "dopplerSpeedGateRange": [
                0.0,
                400.0
              ]
            },
            "updateActiveDetectedTarget": {},
            "setCueToActiveTargetOfInterest": {},
            "setCenterAzimuth": {
              "source": "activeTargetOfInterest"
            },
            "setDistGatePos": {
              "source": "activeTargetOfInterest",
              "width": 0.0
            }
          }
        },
        "switchSelectedTarget": {
          "command": "switchTarget",
          "actions": {
            "setNextDetectedTargetActive": {}
          }
        },
        "setCueAzimuth": {
          "command": "cueAxisX",
          "actions": {
            "setCueAzimuth": {}
          }
        },
        "setCueDist": {
          "command": "cueAxisY",
          "actions": {
            "setCueDist": {}
          }
        },
        "setCueElevation": {
          "command": "cueAxisZ",
          "actions": {
            "setCueElevation": {}
          }
        },
        "setSelectedTarget": {
          "command": "switchToTarget",
          "actions": {
            "setDetectedTargetActive": {}
          }
        }
      }
    },
    "illumination": {
      "stateInit": "init",
      "transitions": {
        "activate": {
          "event": "fsmActivate",
          "stateTo": "active",
          "actions": {
            "checkIlluminationTimeOut": {
              "transiver": true,
              "pauseMax": 20.0
            }
          }
        },
        "deactivate": {
          "event": "fsmDeactivate",
          "stateTo": "inactive",
          "actions": {
            "setIllumination": {
              "transiver": false
            }
          }
        },
        "activateIllumination": {
          "event": "sarhMissileLaunch",
          "actions": {
            "setIlluminationTimeOut": {
              "timeOut": 120.0
            }
          }
        },
        "updateIllumination": {
          "event": "update",
          "actions": {
            "checkIlluminationTimeOut": {
              "transiver": true,
              "pauseMax": 20.0
            }
          }
        }
      }
    }
  }
}