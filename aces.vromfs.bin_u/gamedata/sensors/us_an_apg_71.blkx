      "transitions": {
        "init": {
          "stateFrom": "init",
          "event": "init",
          "stateTo": "standby",
          "actions": {
            "init": {}
          }
        },
        "standbyToSearch": {
          "stateFrom": "standby",
          "command": "switch",
          "event": "enable",
          "stateTo": "search",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetStandbyMode"
              },
              {
                "fsm": "main",
                "name": "setSearchMode"
              }
            ]
          }
        },
        "searchToStandby": {
          "stateFrom": "search",
          "command": "switch",
          "event": "disable",
          "stateTo": "standby",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetSearchMode"
              },
              {
                "fsm": "main",
                "name": "setStandbyMode"
              }
            ]
          }
        },
        "bvrLock": {
          "stateFrom": "search",
          "command": "selectTarget",
          "actions": {
            "doCustomActionTemplate": {
              "fsm": "main",
              "name": "designateTarget"
            }
          }
        },
        "checkDesignationType0": {
          "stateFrom": "search",
          "command": "designateTarget",
          "stateTo": "checkDesignationType0",
          "actions": {
            "checkDesignationTypeEquals": {
              "type": [
                "target",
                "cue"
              ]
            }
          }
        },
        "bvrLockResponce": {
          "stateFrom": "checkDesignationType0",
          "event": "designationTypeEquals",
          "stateTo": "bvrLock",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetSearchMode"
              },
              {
                "fsm": "main",
                "name": "setBvrLockMode"
              }
            ]
          }
        },
        "returnToSearchMode": {
          "stateFrom": "checkDesignationType0",
          "event": "designationTypeNotEquals",
          "stateTo": "search"
        },
        "bvrLockToBvrTrack": {
          "stateFrom": "bvrLock",
          "event": "targetDetected",
          "stateTo": "bvrTrack",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetBvrLockMode"
              },
              {
                "fsm": "main",
                "name": "setBvrTrackMode"
              }
            ]
          }
        },
        "failedBvrLock": {
          "stateFrom": "bvrLock",
          "event": "scanFinished",
          "stateTo": "search",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetBvrLockMode"
              },
              {
                "fsm": "main",
                "name": "setSearchMode"
              }
            ]
          }
        },
        "finishedBvrTrack": {
          "stateFrom": "bvrTrack",
          "event": "targetsOfInterestCleanup",
          "command": [
            "selectTarget",
            "switch"
          ],
          "stateTo": "search",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetBvrTrackMode"
              },
              {
                "fsm": "main",
                "name": "setSearchMode"
              }
            ]
          }
        },
        "finishBvrTrackAndSwitchOff": {
          "stateFrom": "bvrTrack",
          "event": "disable",
          "stateTo": "standby",
          "actions": {
            "doCustomActionTemplate": [
              {
                "fsm": "main",
                "name": "resetBvrTrackMode"
              },
              {
                "fsm": "main",
                "name": "setStandbyMode"
              }
            ]
          }
        },
