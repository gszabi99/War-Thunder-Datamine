{
  "img": {
    "position": "absolute",
    "size": "3sw - 3sw*@isInVr, sh/3+1",
    "pos": "-sw,sh-h-1@bh",
    "background-image": "#ui/gameuiskin#optionlist_background_down"
  },
  "root": {
    "menutitle": {
      "id": "menu-title"
    },
    "tdiv": [
      {
        "id": "bg_picture_container",
        "size": "sw, sh",
        "position": "root",
        "background-color": "@black",
        "tdiv": {
          "pos": "50%sw-50%w,50%sh-50%h",
          "position": "absolute",
          "size": "2.333sh, sh",
          "overflow": "hidden",
          "tdiv": [
            {
              "id": "animated_bg_picture",
              "pos": "pw/2-w/2, ph/2-h/2",
              "position": "absolute",
              "size": "2.5sh, sh",
              "behaviour": "multiLayerImage",
              "blend-time": "500"
            },
            {
              "size": "0.333sh, sh",
              "pos": "-w/2, 0",
              "position": "absolute",
              "background-image": "!ui/gameuiskin#debriefing_bg_grad@@ss",
              "background-color": "@black"
            },
            {
              "size": "0.333sh, sh",
              "pos": "pw -w/2, 0",
              "position": "absolute",
              "background-image": "!ui/gameuiskin#debriefing_bg_grad@@ss",
              "background-color": "@black"
            }
          ]
        }
      },
      {
        "position": "absolute",
        "pos": "@bw + 10%@rw, 0",
        "min-width": "0.35*@sf",
        "height": "sh",
        "flow": "vertical",
        "ShadeDiv": [
          {
            "position": "absolute",
            "pos": "50%pw-50%w, 1@topBarHeight",
            "min-width": "0.35*@sf",
            "width": "100%pw",
            "height": "sh - 1@topBarHeight - 1@bottomBarHeight"
          },
          {
            "position": "absolute",
            "pos": "50%pw-50%w, 0",
            "min-width": "0.33*@sf",
            "width": "pw",
            "height": "1@topBarHeight"
          },
          {
            "position": "absolute",
            "pos": "50%pw-50%w, ph - h",
            "min-width": "0.33*@sf",
            "width": "pw",
            "height": "1@bottomBarHeight"
          }
        ],
        "Red_shadow_light": [
          {
            "position": "absolute",
            "pos": "50%pw-50%w, 0",
            "size": "300%pw, 1@topBarHeight",
            "class": "inverted"
          },
          {
            "position": "absolute",
            "pos": "50%pw-50%w, ph - h",
            "size": "300%pw, 1@bottomBarHeight"
          }
        ],
        "GameLogoPlate": [
          {
            "position": "absolute",
            "pos": "50%pw-50%w, -4",
            "size": "90%pw,20%ph",
            "Shadow": {
              "size": "pw, ph",
              "redPlate": {
                "size": "pw, ph",
                "pattern": {
                  "type": "dark_diag_lines",
                  "size": "pw, ph",
                  "img": {
                    "id": "titleLogo",
                    "position": "relative",
                    "pos": "50%pw-50%w, 50%ph-50%h",
                    "size": "256*@loginLogoScale,128*@loginLogoScale",
                    "background-image": "",
                    "background-repeat": "expand"
                  }
                }
              }
            },
            "tdiv": {
              "position": "absolute",
              "pos": "0,ph-h",
              "width": "pw",
              "height": "0.03@scrn_tgt",
              "versionText": {
                "padding-left": "0.02@scrn_tgt"
              }
            }
          },
          {
            "position": "absolute",
            "size": "90%pw,15%ph",
            "pos": "50%pw-50%w, 85%ph+4",
            "Shadow": {
              "size": "pw, ph",
              "redPlate": {
                "size": "pw, ph",
                "pattern": {
                  "size": "pw, ph",
                  "type": "dark_diag_lines",
                  "CompanyLogo": {
                    "position": "absolute",
                    "pos": "50%pw-50%w, 50%ph-50%h"
                  }
                }
              }
            }
          }
        ],
        "tdiv": {
          "position": "absolute",
          "pos": "50%pw-50%w, 20%ph",
          "size": "90%pw, 65%ph",
          "padding": "4@dp, 0",
          "flow": "vertical",
          "frame": [
            {
              "id": "main_panel_frame",
              "width": "pw",
              "flow": "vertical",
              "input-transparent": "yes",
              "padding": "1@framePadding",
              "class": "authorization",
              "tdiv": [
                {
                  "id": "existing_account_label",
                  "position": "absolute",
                  "top": "1@framePadding",
                  "height": "1@navBarBattleButtonHeight",
                  "width": "pw",
                  "display": "hide",
                  "textarea": {
                    "position": "relative",
                    "pos": "(pw-w)/2, (ph-h)/2",
                    "text-align": "center",
                    "text": "#mainmenu/existingAccount"
                  }
                },
                {
                  "id": "existing_account_block",
                  "position": "relative",
                  "pos": "50%pw-50%w, 0",
                  "width": "pw",
                  "height": "0",
                  "display": "show",
                  "overflow": "hidden",
                  "behaviour": "basicSize",
                  "height-base": "1",
                  "height-end": "100",
                  "size-func": "cube",
                  "size-scale": "child",
                  "size-time": "200",
                  "_size-timer": "1",
                  "tdiv": {
                    "position": "relative",
                    "width": "pw",
                    "left": "(pw-w)/2",
                    "padding-bottom": "2@framePadding",
                    "flow": "vertical",
                    "class": "authorization",
                    "tdiv": {
                      "position": "relative",
                      "width": "pw-0.03@scrn_tgt",
                      "left": "(pw-w)/2",
                      "flow": "vertical",
                      "tdiv": [
                        {
                          "flow": "vertical",
                          "width": "pw",
                          "text": {
                            "text": "#mainmenu/login",
                            "talign": "left",
                            "padding-left": "5",
                            "input-transparent": "yes"
                          },
                          "EditBox": {
                            "id": "loginbox_username",
                            "width": "pw",
                            "noMargin": "yes",
                            "ime-title": "#mainmenu/login",
                            "type": "mail",
                            "_on_activate": "onDoneEnter",
                            "on_change_value": "onChangeLogin",
                            "_on_cancel_edit": "goBack"
                          }
                        },
                        {
                          "flow": "vertical",
                          "width": "pw",
                          "text": {
                            "text": "#mainmenu/password",
                            "talign": "left",
                            "padding-left": "5",
                            "input-transparent": "yes"
                          },
                          "EditBox": {
                            "id": "loginbox_password",
                            "width": "pw",
                            "type": "password",
                            "ime-title": "#mainmenu/password",
                            "_on_activate": "onDoneEnter",
                            "_on_cancel_edit": "goBack",
                            "on_change_value": "setLoginBtnState"
                          },
                          "tdiv": {
                            "position": "relative",
                            "pos": "pw-w-2,0",
                            "smallFont": "yes",
                            "text": [
                              {
                                "id": "loginbox_password_caps_indicator",
                                "overlayTextColor": "warning",
                                "text-align": "right",
                                "text": "#mainmenu/password/capslock",
                                "display": "hide"
                              },
                              {
                                "id": "loginbox_password_layout_indicator",
                                "text": "",
                                "text-align": "right",
                                "padding-left": "1@blockInterval"
                              }
                            ]
                          }
                        },
                        {
                          "id": "sharding_block",
                          "width": "90%pw",
                          "pos": "0, 0.02@scrn_tgt",
                          "position": "relative",
                          "textarea": {
                            "text": "#mainmenu/server",
                            "style": "paragraph-indent:0;",
                            "input-transparent": "yes",
                            "inactive": "yes"
                          },
                          "tdiv": {
                            "id": "sharding_dropright_block",
                            "width": "fw",
                            "margin-left": "0.032@scrn_tgt",
                            "class": "circuitDropright"
                          }
                        }
                      ],
                      "LoginCheckBoxesBlock": {
                        "id": "login_boxes_block",
                        "flow": "vertical",
                        "width": "pw",
                        "CheckBox": [
                          {
                            "id": "loginbox_remote_comp",
                            "width": "pw",
                            "pos": "0, 0",
                            "position": "relative",
                            "display": "show",
                            "enable": "yes",
                            "_on_change_value": "onChangeAutosave",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "width": "pw",
                              "position": "relative",
                              "pos": "0, 50%ph-50%h",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#options/remote_device",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          },
                          {
                            "id": "loginbox_code_remember_this_device",
                            "position": "relative",
                            "width": "pw",
                            "pos": "0, 0",
                            "display": "hide",
                            "enable": "no",
                            "_on_change_value": "onChangeAutosave",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "width": "pw",
                              "position": "relative",
                              "pos": "0, 50%ph-50%h",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#options/remember_cur_device",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          },
                          {
                            "id": "loginbox_autosave_login",
                            "pos": "0, 0.02@scrn_tgt",
                            "position": "relative",
                            "width": "pw-0.025@scrn_tgt",
                            "_on_change_value": "onChangeAutosave",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "width": "pw",
                              "position": "relative",
                              "pos": "0, 50%ph-50%h",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#mainmenu/saveLogin",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          },
                          {
                            "id": "loginbox_autosave_password",
                            "position": "relative",
                            "pos": "0, 0.015@scrn_tgt",
                            "width": "pw",
                            "_on_change_value": "onChangeAutosave",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "id": "loginbox_autosave_password_text",
                              "position": "relative",
                              "pos": "0, 0.5ph-0.5h",
                              "width": "pw",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#mainmenu/savePassword",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          },
                          {
                            "id": "loginbox_disable_ssl_cert",
                            "position": "relative",
                            "pos": "0, 0.015@scrn_tgt",
                            "width": "pw",
                            "_on_change_value": "onChangeAutosave",
                            "display": "hide",
                            "enable": "no",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "width": "pw",
                              "position": "relative",
                              "pos": "0, 0.005@sf",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#mainmenu/disableSSLCert",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          },
                          {
                            "id": "loginbox_autologin",
                            "position": "relative",
                            "pos": "0, 0.015@scrn_tgt",
                            "width": "pw",
                            "btnName": "SpaceA",
                            "ButtonImg": {},
                            "textarea": {
                              "width": "pw",
                              "position": "relative",
                              "pos": "0, 50%ph-50%h",
                              "style": "wrap-indent:0; paragraph-indent:0;",
                              "smallFont": "yes",
                              "text": "#options/auto_login",
                              "input-transparent": "yes"
                            },
                            "CheckBoxImg": {}
                          }
                        ],
                        "button": {
                          "id": "btn_recovery_link",
                          "position": "relative",
                          "pos": "0, 0.01@scrn_tgt",
                          "noMargin": "yes",
                          "tfont": "small",
                          "talign": "left",
                          "class": "link",
                          "_on_click": "onForgetPassword",
                          "text": "#msgbox/btn_recovery",
                          "btnName": "SpaceA",
                          "ButtonImg": {},
                          "focus_border": {},
                          "underline": {}
                        }
                      }
                    },
                    "Button_text": [
                      {
                        "id": "steam_login_action_button",
                        "text": "#mainmenu/loginWithSteam",
                        "margin-bottom": "1@blockInterval",
                        "css-hier-invalidate": "yes",
                        "btnName": "LB",
                        "focusBtnName": "A",
                        "_on_click": "onSteamAuthorization",
                        "visualStyle": "secondary",
                        "buttonWink": {},
                        "ButtonImg": {}
                      },
                      {
                        "id": "login_action_button",
                        "class": "battle",
                        "navButtonFont": "yes",
                        "margin-top": "1@blockInterval",
                        "text": "#msgbox/btn_signIn",
                        "_on_click": "onOk",
                        "css-hier-invalidate": "yes",
                        "btnName": "X",
                        "focusBtnName": "A",
                        "pattern": {
                          "type": "bright_texture"
                        },
                        "buttonWink": {
                          "_transp-timer": "0"
                        },
                        "buttonGlance": {},
                        "btnText": {
                          "text": "#msgbox/btn_signIn"
                        },
                        "ButtonImg": {}
                      },
                      {
                        "id": "sso_login_action_button",
                        "text": "#mainmenu/loginWithSso",
                        "margin-bottom": "1@blockInterval",
                        "margin-top": "1@blockInterval",
                        "css-hier-invalidate": "yes",
                        "btnName": "RB",
                        "focusBtnName": "A",
                        "_on_click": "onSsoAuthorization",
                        "hideText": "yes",
                        "externalLink": "yes",
                        "hasConsoleImage": "yes",
                        "ButtonImg": {},
                        "btnText": {
                          "text": "#mainmenu/loginWithSso",
                          "underline": {}
                        }
                      }
                    ]
                  }
                }
              ],
              "Button_text": [
                {
                  "id": "usual_login_btn",
                  "position": "absolute",
                  "top": "1@framePadding",
                  "text": "#mainmenu/existingAccount",
                  "css-hier-invalidate": "yes",
                  "btnName": "LB",
                  "focusBtnName": "A",
                  "display": "hide",
                  "_on_click": "openExistingAccountPanel",
                  "behaviour": "massTransparency",
                  "transp-base": "255",
                  "transp-func": "cube",
                  "transp-end": "255",
                  "transp-time": "200",
                  "_transp-timer": "1",
                  "selfRemoveOnFinish": "0",
                  "color-factor": "255",
                  "ButtonImg": {}
                },
                {
                  "id": "guest_login_action_button",
                  "margin-bottom": "1@blockInterval",
                  "text": "#mainmenu/loginWithGuest",
                  "css-hier-invalidate": "yes",
                  "btnName": "LT",
                  "focusBtnName": "A",
                  "_on_click": "onGuestAuthorization",
                  "ButtonImg": {}
                }
              ]
            },
            {
              "size": "pw, fh",
              "margin-top": "1@blockInterval",
              "tdiv": {
                "id": "links_block",
                "position": "relative",
                "pos": "0.015@scrn_tgt, 0",
                "flow": "vertical",
                "button": [
                  {
                    "id": "btn_signUp_link",
                    "position": "relative",
                    "pos": "0, 0.015@scrn_tgt",
                    "text": "#mainmenu/signUp",
                    "_on_click": "onSignUp",
                    "noMargin": "yes",
                    "tfont": "small",
                    "talign": "left",
                    "class": "link",
                    "btnName": "SpaceA",
                    "ButtonImg": {},
                    "focus_border": {},
                    "underline": {}
                  },
                  {
                    "id": "btn_faq_link",
                    "text": "#mainmenu/faq",
                    "on_click": "onMsgLink",
                    "link": "#url/faq",
                    "bqKey": "login_page",
                    "tfont": "small",
                    "class": "link",
                    "talign": "left",
                    "noMargin": "yes",
                    "btnName": "SpaceA",
                    "ButtonImg": {},
                    "focus_border": {},
                    "underline": {}
                  },
                  {
                    "id": "btn_support_link",
                    "text": "#mainmenu/support",
                    "on_click": "onMsgLink",
                    "link": "#url/support",
                    "bqKey": "login_page",
                    "class": "link",
                    "noMargin": "yes",
                    "tfont": "small",
                    "talign": "left",
                    "btnName": "SpaceA",
                    "ButtonImg": {},
                    "underline": {}
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "id": "browser_bug_disclaimer",
        "position": "absolute",
        "pos": "50%pw-50%w, 83%sh - 1@bh -50%h",
        "width": "0.8sw - 0.8*@sf",
        "flow": "vertical",
        "background-color": "@shadeBackgroundColor4",
        "background-repeat": "expand",
        "padding": "0.005sw, 0.01sh, 0.005sw, 0.02sh",
        "textAreaCentered": {
          "position": "relative",
          "pos": "(pw-w)/2, 0",
          "width": "pw",
          "text": "#browser_bug_disclaimer",
          "style": "color:@warningTextColor;"
        }
      }
    ],
    "div": {
      "behaviour": "button",
      "size": "sw,sh",
      "position": "root",
      "on_click": "onClosePopups"
    },
    "ProjectAwardsPanel": {
      "id": "project-awards"
    },
    "TopMenuPanel": {
      "input-transparent": "yes",
      "shadowSafeArea": {},
      "tdiv": [
        {
          "size": "1@swOrRwInVr, ph-(1@bh+1@topGamercardDarkLineHeight)*1@isInVr",
          "pos": "1@bwInVr, (1@bh-1@topGamercardDarkLineHeight)*1@isInVr",
          "position": "absolute",
          "TopMenuPanelBg": {
            "width": "pw"
          }
        },
        {
          "position": "absolute",
          "pos": "pw-w-1@bw, 1@bh",
          "tdiv": {
            "id": "language_selector",
            "position": "relative",
            "pos": "0, ph/2-h/2",
            "display": "hide",
            "text": {
              "id": "label_language",
              "position": "relative",
              "pos": "0, ph/2-h/2",
              "text": "#profile/language",
              "talign": "left",
              "margin": "@sIco/8, 0, @sIco/4, 0",
              "input-transparent": "yes",
              "inactive": "yes"
            },
            "Button_text": {
              "id": "btn_language",
              "position": "relative",
              "noMargin": "yes",
              "visualStyle": "noFrame",
              "imgSize": "big",
              "on_click": "onPopupLanguages",
              "popupMenuBrightIcons": "yes",
              "popupMenuWithoutHover": "yes",
              "btnName": "Y",
              "ButtonImg": {},
              "cardImg": {
                "id": "btn_language_icon",
                "background-image": "#ui/gameuiskin#lang_usa.svg"
              },
              "btnText": {
                "id": "btn_language_text",
                "position": "relative",
                "pos": "@blockInterval, 50%ph-50%h",
                "text": "#profile/language/en",
                "text-align": "left"
              }
            }
          },
          "Button_close": {
            "id": "button_exit",
            "_on_click": "goBack",
            "relative": "yes"
          }
        }
      ]
    },
    "BottomMenuPanel": {
      "input-transparent": "yes",
      "shadowSafeArea": {},
      "line": {},
      "tdiv": {
        "behavior": "bhvUpdater",
        "value": "{\"viewId\": \"COPYRIGHT_TEXT\"}",
        "css-hier-invalidate": "yes",
        "pos": "pw-w-1@bw, 50%ph - 50%h",
        "position": "absolute",
        "copyright": {
          "id": "copyright_text"
        }
      }
    }
  },
  "dummy": {
    "behavior": "button",
    "_on_click": "onKbdWrapDown",
    "accesskey": "Tab"
  }
}