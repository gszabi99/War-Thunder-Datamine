{
  "hitCameraRender": {
    "id": "hit_camera_render",
    "tdiv": [
      {
        "position": "absolute",
        "id": "indicators_nest"
      },
      {
        "size": "pw, ph",
        "position": "absolute",
        "overflow": "hidden",
        "hitCameraCritAnim": {
          "id": "critAnim",
          "height": "1@hitCameraHeight",
          "needAnim": "no",
          "_size-timer": "0",
          "_transp-timer": "0",
          "color-factor": "255"
        }
      }
    ],
    "hitCameraTitle": {
      "id": "title"
    },
    "enemyDamageStatusPanel": {
      "flow": "vertical",
      "tdiv": {
        "id": "damageStatus",
        "pos": "0.5pw-0.5w, 0",
        "position": "relative"
      }
    },
    "hitCameraInfo": {
      "id": "info",
      "margin-top": "0.5@hitcamDebuffPadding",
      "flow": "horizontal"
    }
  }
}