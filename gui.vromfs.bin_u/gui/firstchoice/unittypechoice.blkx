{
  "root": {
    "blur": {},
    "blur_foreground": {},
    "tdiv": {
      "max-width": "1@rw",
      "max-height": "1@rh",
      "pos": "50%pw-50%w, 50%ph-50%h",
      "position": "absolute",
      "flow": "vertical",
      "tdiv": {
        "id": "usernick_place",
        "position": "relative",
        "left": "50%pw-50%w",
        "margin-bottom": "2.5@blockInterval"
      },
      "textareaNoTab": {
        "overlayTextColor": "active",
        "bigBoldFont": "yes",
        "position": "relative",
        "left": "50%pw-50%w",
        "margin-bottom": "8@blockInterval",
        "font": "@fontBigBold",
        "text": "#mainmenu/firstUnit"
      },
      "div": {
        "id": "first_choices_block",
        "width": "pw"
      },
      "textAreaCentered": {
        "overlayTextColor": "active",
        "position": "relative",
        "max-width": "0.95pw",
        "left": "50%pw-50%w",
        "margin-top": "8@blockInterval",
        "text": "#mainmenu/firstUnitChoiceBonusNotice"
      }
    }
  }
}