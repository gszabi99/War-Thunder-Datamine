tdiv {
  height:t='1@firstChoiceUserIconHeight'

  avatar {
    behavior:t='bhvAvatar'
    position:t='relative'
    size:t='ph, ph'
    isFull:t='yes'
    css-hier-invalidate:t='yes'
    value:t='<<userIcon>>'
    margin-right:t='3@blockInterval'

    avatarFrame {
      background-image:t='<<userFrame>>'
    }
  }

  textareaNoTab {
    overlayTextColor:t='active'
    caption:t='yes'
    top:t='0.5ph-0.5h'
    position:t='relative'
    text:t='<<userName>>'
  }
}
