{
  "tdiv": [
    {
      "id": "hud_tutorial_helicopter_vertical_speed",
      "_set_aabb_by_object": "verticalSpeed",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "0.5(pw-w), -60/720@shHud-h",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/vertical_speed"
      },
      "img": {
        "position": "absolute",
        "pos": "0.3(pw-w), -65/720@shHud",
        "size": "30/720@shHud, 65/720@shHud",
        "rotation": "215",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_velocity_vector",
      "_set_aabb_by_object": "velocityVector",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "-w,-50/720@shHud",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/velocity_vector_marker"
      },
      "img": {
        "position": "absolute",
        "pos": "-w,-50/720@shHud",
        "size": "30/720@shHud, 75/720@shHud",
        "rotation": "115",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_altimeter",
      "_set_aabb_by_object": "altimeter",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "0.9*pw,-80/720@shHud-h",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/altimeter"
      },
      "img": {
        "position": "absolute",
        "pos": "0.9*pw,-80/720@shHud",
        "size": "30/720@shHud, 75/720@shHud",
        "rotation": "205",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_attitude_indicator",
      "_set_aabb_by_object": "attitudeIndicator",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "-w-40/720@shHud,h+10/720@shHud",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/attitude_indicator"
      },
      "img": {
        "position": "absolute",
        "pos": "-w/2,ph-30/720@shHud",
        "size": "30/720@shHud, 75/720@shHud",
        "rotation": "80",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_rotor_pitch",
      "_set_aabb_by_object": "rotorPitch0",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "-w-20/720@shHud,-h-50/720@shHud",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/helicopter_rotor_pitch"
      },
      "img": {
        "position": "absolute",
        "pos": "-w-15/720@shHud,-h+15/720@shHud",
        "size": "30/720@shHud, 75/720@shHud",
        "rotation": "135",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_rotor_rpm",
      "_set_aabb_by_object": "rotorRpm",
      "position": "absolute",
      "display": "hide",
      "textareaNoTab": {
        "position": "absolute",
        "pos": "-w-20/720@shHud,-h-50/720@shHud",
        "shadeStyle": "HudHeader3D",
        "style": "font:@fontHudNormal; text-align:right; color:#ffffff;",
        "text": "#controls/help/helicopter_rotor_rpm"
      },
      "img": {
        "position": "absolute",
        "pos": "-w-15/720@shHud,-h+15/720@shHud",
        "size": "30/720@shHud, 75/720@shHud",
        "rotation": "135",
        "background-image": "@!ui/images/tutorial/tutorial_tank_arrow_yellow"
      }
    },
    {
      "id": "hud_tutorial_helicopter_speed",
      "_set_aabb_by_object": "speed",
